Options -Indexes -MultiViews
DirectoryIndex index.html

RewriteEngine On
ErrorDocument 503 /manutencao.html

# Maintenance mode: create maintenance.flag to show manutencao.html on public routes.
RewriteCond %{DOCUMENT_ROOT}/maintenance.flag -f
RewriteCond %{REQUEST_URI} !^/manutencao(?:\.html)?/?$ [NC]
RewriteCond %{REQUEST_URI} !^/(assets|api)(?:/|$) [NC]
RewriteCond %{REQUEST_URI} !^/(favicon\.ico|favicon-[0-9]+x[0-9]+\.png|apple-touch-icon\.png|site\.webmanifest|robots\.txt)$ [NC]
RewriteRule ^ - [R=503,L]

# Keep the homepage canonical without the physical index file.
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html[?\s] [NC]
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L,NE]

# Redirect public .html URLs to clean equivalents while preserving queries.
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[?\s] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L,NE]

# Avoid trailing slashes on clean URLs backed by .html files.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)/$ /$1 [R=301,L,NE]

# Serve clean URLs from their matching .html files.
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+)$ $1.html [L]
