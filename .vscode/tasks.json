{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GitHub: salvar versao",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/salvar-github.cmd",
      "args": [
        "${input:commitMessage}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Mensagem do commit",
      "default": "Atualizacao"
    }
  ]
}
